# ─── App ───────────────────────────────────────────────
APP_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:8000

# ─── Database ──────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/dbname

# ─── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0


# ─── Auth (Clerk) ──────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_pub_key
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
# CLERK_WEBHOOK_SECRET=whsec_...

# Local fallback auth (used when Clerk is unavailable)
# If USE_CLERK=false local signup/login endpoints will be used.
USE_CLERK=true
JWT_SECRET_KEY=replace-me-with-a-secure-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ─── AI Providers ──────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_AI_API_KEY=...

# ─── Pinecone ──────────────────────────────────────────
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX=applypilot-jobs
PINECONE_ENVIRONMENT=us-east-1-aws

# ─── Stripe ────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_pub_key

# ─── Observability ─────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── Job Sources (optional API keys) ───────────────────
LINKEDIN_RAPIDAPI_KEY=87238b6a40msh74ac444d25cc3e5p1cfd49jsn6bb11f7ac665
INDEED_PUBLISHER_ID=
